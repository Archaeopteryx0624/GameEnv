<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>0x City</title>
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; overflow: hidden; background: #111; touch-action: none; user-select: none; font-family: 'Courier New', monospace; }
    #canvas-container { width: 100vw; height: 100vh; position: absolute; top: 0; left: 0; z-index: 1; }
    #hud { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; pointer-events: none; }

    /* Minimap */
    #minimap-wrap {
      position: absolute; top: 16px; right: 16px;
      width: 130px; height: 130px;
      border: 2px solid rgba(255,200,0,0.7); border-radius: 4px;
      background: rgba(0,0,0,0.75); overflow: hidden;
    }
    #minimap { width: 100%; height: 100%; }
    #minimap-player {
      position: absolute; top: 50%; left: 50%;
      width: 7px; height: 7px; background: #ffe000; border-radius: 50%;
      transform: translate(-50%,-50%); box-shadow: 0 0 6px #ffe000;
    }
    #minimap-label { position: absolute; bottom: 2px; right: 5px; color: rgba(255,200,0,0.6); font-size: 9px; letter-spacing: 1px; }

    /* Clock */
    #clock-wrap {
      position: absolute; top: 160px; right: 16px;
      width: 130px; text-align: center;
      color: #ffe000; font-size: 18px; font-weight: bold; letter-spacing: 3px;
      text-shadow: 0 0 8px rgba(255,200,0,0.5);
    }
    #clock-period { font-size: 10px; letter-spacing: 2px; opacity: 0.7; }

    /* Stats */
    #stats { position: absolute; top: 16px; left: 16px; display: flex; flex-direction: column; gap: 6px; }
    .stat-row { display: flex; align-items: center; gap: 8px; }
    .stat-label { color: rgba(255,200,0,0.8); font-size: 11px; letter-spacing: 2px; width: 28px; }
    .stat-bar-bg { width: 90px; height: 8px; background: rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden; }
    .stat-bar { height: 100%; border-radius: 2px; transition: width 0.2s; }
    #health-bar { background: linear-gradient(90deg, #ef4444, #f87171); width: 100%; }
    #wanted-bar { background: linear-gradient(90deg, #ffe000, #fbbf24); width: 0%; }
    .stat-val { color: rgba(255,255,255,0.7); font-size: 10px; min-width: 28px; }

    /* In-car indicator */
    #car-hud {
      position: absolute; bottom: 220px; left: 16px;
      display: none; flex-direction: column; gap: 4px;
    }
    #car-hud.active { display: flex; }
    #car-label { color: #ffe000; font-size: 10px; letter-spacing: 2px; }
    #car-speed-val { color: #fff; font-size: 22px; font-weight: bold; }
    #car-speed-unit { color: rgba(255,200,0,0.6); font-size: 9px; }

    /* Inventory */
    #inventory { position: absolute; bottom: 220px; right: 16px; display: flex; flex-direction: column; gap: 4px; }
    #inv-label { color: rgba(255,200,0,0.7); font-size: 10px; letter-spacing: 2px; text-align: right; margin-bottom: 2px; }
    .inv-slot {
      width: 48px; height: 48px; border: 1px solid rgba(255,200,0,0.3);
      background: rgba(0,0,0,0.6); border-radius: 4px;
      display: flex; align-items: center; justify-content: center; font-size: 22px;
      transition: border-color 0.2s, background 0.2s; position: relative;
    }
    .inv-slot.filled { border-color: rgba(255,200,0,0.8); background: rgba(255,200,0,0.08); }
    .inv-slot .qty { position: absolute; bottom: 2px; right: 4px; font-size: 9px; color: #ffe000; font-weight: bold; }

    /* Pickup popup */
    #pickup-popup {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -80px);
      background: rgba(0,0,0,0.85); border: 1px solid rgba(255,200,0,0.6);
      color: #ffe000; padding: 8px 18px; font-size: 13px; letter-spacing: 2px;
      border-radius: 3px; opacity: 0; transition: opacity 0.3s; pointer-events: none; text-align: center;
    }
    #pickup-popup.show { opacity: 1; }

    /* Notify */
    #notify { position: absolute; top: 110px; right: 160px; display: flex; flex-direction: column; gap: 4px; align-items: flex-end; }
    .notify-item {
      background: rgba(0,0,0,0.8); border-left: 3px solid #ffe000;
      color: rgba(255,255,255,0.9); padding: 5px 10px; font-size: 11px; letter-spacing: 1px;
      animation: fadeNotify 3s forwards; pointer-events: none;
    }
    .notify-item.red { border-left-color: #ef4444; }
    .notify-item.blue { border-left-color: #3b82f6; }
    @keyframes fadeNotify {
      0%{opacity:0;transform:translateX(10px)} 10%{opacity:1;transform:translateX(0)}
      75%{opacity:1} 100%{opacity:0}
    }

    /* Speech bubble */
    .speech-bubble {
      position: absolute; background: rgba(0,0,0,0.85); border: 1px solid rgba(255,200,0,0.5);
      color: #fff; padding: 5px 10px; font-size: 11px; border-radius: 3px;
      pointer-events: none; white-space: nowrap; transform: translate(-50%,-100%); z-index: 20;
    }
    .speech-bubble.cop { border-color: #3b82f6; color: #93c5fd; }

    /* Joystick */
    #joystick-zone {
      position: absolute; bottom: 40px; left: 40px;
      width: 140px; height: 140px;
      background: rgba(255,255,255,0.06); border: 2px solid rgba(255,200,0,0.2);
      border-radius: 50%; z-index: 10; touch-action: none; pointer-events: all; backdrop-filter: blur(3px);
    }
    #joystick-knob {
      position: absolute; top: 50%; left: 50%; width: 52px; height: 52px;
      background: rgba(255,200,0,0.85); border-radius: 50%;
      transform: translate(-50%,-50%); box-shadow: 0 4px 15px rgba(255,200,0,0.3); pointer-events: none;
    }

    /* Action buttons */
    #action-btns { position: absolute; bottom: 50px; right: 200px; display: flex; gap: 12px; z-index: 10; pointer-events: all; }
    .act-btn {
      width: 54px; height: 54px; border-radius: 50%;
      border: 2px solid rgba(255,200,0,0.5); background: rgba(0,0,0,0.6);
      color: #ffe000; font-size: 20px; display: flex; align-items: center; justify-content: center;
      cursor: pointer; backdrop-filter: blur(4px); transition: background 0.15s, transform 0.1s;
      user-select: none; -webkit-tap-highlight-color: transparent;
    }
    .act-btn:active { background: rgba(255,200,0,0.25); transform: scale(0.93); }

    /* Speed bar */
    #speed-wrap {
      position: absolute; bottom: 40px; right: 16px;
      width: 18px; height: 140px; background: rgba(255,255,255,0.07);
      border-radius: 9px; overflow: hidden; border: 1px solid rgba(255,200,0,0.2);
    }
    #speed-fill {
      position: absolute; bottom: 0; left: 0; width: 100%;
      background: linear-gradient(to top, #4ade80, #facc15, #ef4444); height: 0%; transition: height 0.1s;
    }

    /* Title */
    #city-title {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      color: #ffe000; font-size: 48px; font-weight: 900; letter-spacing: 12px;
      text-shadow: 0 0 40px rgba(255,200,0,0.6), 0 0 2px #000;
      opacity: 1; transition: opacity 2s; pointer-events: none; text-transform: uppercase;
    }
    #city-subtitle {
      position: absolute; top: calc(50% + 52px); left: 50%; transform: translateX(-50%);
      color: rgba(255,200,0,0.5); font-size: 12px; letter-spacing: 6px;
      opacity: 1; transition: opacity 2s; pointer-events: none;
    }

    /* Wanted flash overlay */
    #wanted-flash {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none; border: 0px solid rgba(239,68,68,0);
      transition: border-width 0.1s, border-color 0.1s;
    }
    #wanted-flash.active { border: 8px solid rgba(239,68,68,0.6); box-shadow: inset 0 0 40px rgba(239,68,68,0.2); }
  </style>
  <script src="/libs/js/three.min.js"></script>
  <script src="/libs/js/OrbitControls.js"></script>
</head>
<body>

<div id="canvas-container"></div>

<div id="hud">
  <div id="city-title">0X CITY</div>
  <div id="city-subtitle">OPEN WORLD</div>
  <div id="wanted-flash"></div>

  <div id="minimap-wrap">
    <canvas id="minimap" width="130" height="130"></canvas>
    <div id="minimap-player"></div>
    <div id="minimap-label">MAP</div>
  </div>

  <div id="clock-wrap">
    <div id="clock-time">12:00</div>
    <div id="clock-period">NOON</div>
  </div>

  <div id="stats">
    <div class="stat-row">
      <div class="stat-label">HP</div>
      <div class="stat-bar-bg"><div class="stat-bar" id="health-bar"></div></div>
      <div class="stat-val" id="health-val">100</div>
    </div>
    <div class="stat-row">
      <div class="stat-label">★</div>
      <div class="stat-bar-bg"><div class="stat-bar" id="wanted-bar"></div></div>
      <div class="stat-val" id="wanted-val">0</div>
    </div>
  </div>

  <div id="car-hud">
    <div id="car-label">🚗 IN VEHICLE</div>
    <div><span id="car-speed-val">0</span> <span id="car-speed-unit">KM/H</span></div>
  </div>

  <div id="inventory">
    <div id="inv-label">INVENTORY</div>
    <div class="inv-slot" id="slot-0"><span class="qty" id="qty-0"></span></div>
    <div class="inv-slot" id="slot-1"><span class="qty" id="qty-1"></span></div>
    <div class="inv-slot" id="slot-2"><span class="qty" id="qty-2"></span></div>
    <div class="inv-slot" id="slot-3"><span class="qty" id="qty-3"></span></div>
  </div>

  <div id="pickup-popup">▲ INTERACT</div>
  <div id="notify"></div>

  <div id="speed-wrap"><div id="speed-fill"></div></div>
  <div id="joystick-zone"><div id="joystick-knob"></div></div>

  <div id="action-btns">
    <div class="act-btn" id="btn-pickup" title="Interact [E]">🤜</div>
    <div class="act-btn" id="btn-run" title="Sprint">⚡</div>
  </div>
</div>

<script>
(function () {
if (typeof OrbitControls === 'undefined' && THREE.OrbitControls) window.OrbitControls = THREE.OrbitControls;

// ═══════════════════════════════════════
//  CONFIG
// ═══════════════════════════════════════
const CFG = {
  moveSpeed: 0.12, runMultiplier: 2.2, rotSpeed: 0.12,
  joystickMaxDist: 45, pickupRadius: 2.8,
  npcCount: 8, copCount: 3,
  carCount: 8,
  citySize: 50, blockSize: 12, roadWidth: 5,
  carColors: [0xe74c3c, 0x3498db, 0x2ecc71, 0xf39c12, 0x9b59b6, 0x1abc9c, 0xe67e22, 0xecf0f1, 0x34495e],
  itemDefs: [
    { emoji:'💊', name:'MedKit',  color:0xe74c3c },
    { emoji:'💰', name:'Cash',    color:0xf1c40f },
    { emoji:'🔑', name:'Key',     color:0x2ecc71 },
    { emoji:'🔫', name:'Weapon',  color:0x95a5a6 },
    { emoji:'⭐', name:'Star',    color:0xf39c12 },
    { emoji:'📦', name:'Package', color:0x3498db },
  ],
  npcPhrases: ["Hey, watch it!", "Nice day, huh?", "Stay outta trouble.", "I saw nothin'!", "Move along.", "You new here?", "Keep walking.", "Eyes forward, pal."],
  copPhrases: ["FREEZE!", "Stop right there!", "You're under arrest!", "Don't run!", "End of the line!", "Hands up!"],
  copNpcPhrases: ["Come with me!", "Stop resisting!", "You're coming with us!"],
};

// ═══════════════════════════════════════
//  STATE
// ═══════════════════════════════════════
const state = {
  moveForward: 0, moveRight: 0, isMoving: false, isSprinting: false,
  health: 100, wanted: 0,
  inventory: [],
  nearItem: null, nearCar: null,
  inCar: null,          // car object player is driving
  gameTime: 720,        // minutes since midnight (720 = noon)
  wantedFlashTimer: 0,
};

// ═══════════════════════════════════════
//  SCENE
// ═══════════════════════════════════════
const container = document.getElementById('canvas-container');
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x87ceeb); // starts as day sky
scene.fog = new THREE.Fog(0x87ceeb, 20, 80);

const camera = new THREE.PerspectiveCamera(60, innerWidth/innerHeight, 0.1, 200);
camera.position.set(0, 7, 12);

const renderer = new THREE.WebGLRenderer({ antialias: false });
renderer.setSize(innerWidth, innerHeight);
renderer.setPixelRatio(1);
renderer.shadowMap.enabled = false;
container.appendChild(renderer.domElement);

// Lights — brighter, full ambient + directional sun
const ambient = new THREE.AmbientLight(0xffffff, 0.9);
scene.add(ambient);
const sunLight = new THREE.DirectionalLight(0xfff5e0, 1.2);
sunLight.position.set(30, 50, 20);
scene.add(sunLight);

// ═══════════════════════════════════════
//  DAY/NIGHT SYSTEM
// ═══════════════════════════════════════
const skyColors = {
  day:   new THREE.Color(0x87ceeb),
  dusk:  new THREE.Color(0xff7043),
  night: new THREE.Color(0x0a0a20),
  dawn:  new THREE.Color(0xff8a65),
};
function updateDayNight(dt) {
  state.gameTime = (state.gameTime + dt * 2) % 1440; // 1 real sec = 2 game min
  const h = state.gameTime / 60; // 0–24
  let sky, sunI, ambI;
  if (h >= 6 && h < 9) {
    const f = (h-6)/3;
    sky = skyColors.dawn.clone().lerp(skyColors.day, f);
    sunI = 0.4 + f*0.8; ambI = 0.4 + f*0.5;
  } else if (h >= 9 && h < 17) {
    sky = skyColors.day.clone(); sunI = 1.2; ambI = 0.9;
  } else if (h >= 17 && h < 20) {
    const f = (h-17)/3;
    sky = skyColors.day.clone().lerp(skyColors.dusk, f);
    sunI = 1.2 - f*0.9; ambI = 0.9 - f*0.5;
  } else if (h >= 20 && h < 22) {
    const f = (h-20)/2;
    sky = skyColors.dusk.clone().lerp(skyColors.night, f);
    sunI = 0.3 - f*0.25; ambI = 0.4 - f*0.25;
  } else {
    sky = skyColors.night.clone(); sunI = 0.05; ambI = 0.15;
  }
  scene.background = sky;
  scene.fog.color = sky;
  sunLight.intensity = sunI;
  ambient.intensity = ambI;

  // Clock HUD
  const hh = Math.floor(state.gameTime / 60) % 24;
  const mm = Math.floor(state.gameTime % 60);
  const ampm = hh < 12 ? 'AM' : 'PM';
  const hDisp = ((hh % 12) || 12).toString().padStart(2,'0');
  document.getElementById('clock-time').textContent = `${hDisp}:${mm.toString().padStart(2,'0')}`;
  document.getElementById('clock-period').textContent = ampm;
}

// ═══════════════════════════════════════
//  CITY
// ═══════════════════════════════════════
const buildingMats = [
  new THREE.MeshStandardMaterial({ color:0xcc8866, roughness:0.8 }),
  new THREE.MeshStandardMaterial({ color:0x8899aa, roughness:0.7 }),
  new THREE.MeshStandardMaterial({ color:0xaabb99, roughness:0.7 }),
  new THREE.MeshStandardMaterial({ color:0xddcc99, roughness:0.8 }),
  new THREE.MeshStandardMaterial({ color:0x99aacc, roughness:0.7 }),
];
const buildings = [];

function buildCity() {
  const groundMat = new THREE.MeshStandardMaterial({ color:0x558844, roughness:1 });
  const ground = new THREE.Mesh(new THREE.PlaneGeometry(200, 200), groundMat);
  ground.rotation.x = -Math.PI/2; scene.add(ground);

  const roadMat = new THREE.MeshStandardMaterial({ color:0x555566, roughness:0.9 });
  const sidewalkMat = new THREE.MeshStandardMaterial({ color:0xbbbbaa, roughness:0.9 });
  const numBlocks = Math.floor(CFG.citySize / (CFG.blockSize + CFG.roadWidth));

  for (let bx = -numBlocks/2; bx <= numBlocks/2; bx++) {
    for (let bz = -numBlocks/2; bz <= numBlocks/2; bz++) {
      const cx = bx * (CFG.blockSize + CFG.roadWidth);
      const cz = bz * (CFG.blockSize + CFG.roadWidth);

      const r1 = new THREE.Mesh(new THREE.PlaneGeometry(CFG.blockSize + CFG.roadWidth, CFG.roadWidth), roadMat);
      r1.rotation.x = -Math.PI/2; r1.position.set(cx, 0.01, cz - CFG.blockSize/2 - CFG.roadWidth/2); scene.add(r1);

      const r2 = new THREE.Mesh(new THREE.PlaneGeometry(CFG.roadWidth, CFG.blockSize + CFG.roadWidth), roadMat);
      r2.rotation.x = -Math.PI/2; r2.position.set(cx - CFG.blockSize/2 - CFG.roadWidth/2, 0.01, cz); scene.add(r2);

      const sw = new THREE.Mesh(new THREE.PlaneGeometry(CFG.blockSize, CFG.blockSize), sidewalkMat);
      sw.rotation.x = -Math.PI/2; sw.position.set(cx, 0.02, cz); scene.add(sw);

      const numB = 1 + Math.floor(Math.random() * 2);
      for (let b = 0; b < numB; b++) {
        const bw = 2 + Math.random() * 5, bd = 2 + Math.random() * 5, bh = 3 + Math.random() * 12;
        const offX = (Math.random() - 0.5) * (CFG.blockSize - bw);
        const offZ = (Math.random() - 0.5) * (CFG.blockSize - bd);
        const mat = buildingMats[Math.floor(Math.random() * buildingMats.length)];
        const mesh = new THREE.Mesh(new THREE.BoxGeometry(bw, bh, bd), mat);
        mesh.position.set(cx+offX, bh/2, cz+offZ);
        scene.add(mesh);
        buildings.push({ bw, bd, x: cx+offX, z: cz+offZ });
      }
    }
  }
}
buildCity();

// ═══════════════════════════════════════
//  CHARACTER FACTORY
// ═══════════════════════════════════════
function createCharacter(colors) {
  const g = new THREE.Group();
  const mk = (geo, mat) => new THREE.Mesh(geo, mat);
  const skinMat = new THREE.MeshStandardMaterial({ color: colors.skin||0xffcd94, roughness:0.5 });
  const shirtMat = new THREE.MeshStandardMaterial({ color: colors.shirt||0x3b82f6, roughness:0.7 });
  const pantsMat = new THREE.MeshStandardMaterial({ color: colors.pants||0x1e3a8a, roughness:0.8 });
  const shoeMat  = new THREE.MeshStandardMaterial({ color: 0x111111, roughness:0.9 });

  const torso = mk(new THREE.BoxGeometry(0.6, 0.7, 0.3), shirtMat);
  torso.position.y = 1.35; g.add(torso);
  const head = mk(new THREE.BoxGeometry(0.35, 0.35, 0.35), skinMat);
  head.position.y = 0.55; torso.add(head);

  const laG = new THREE.Group(); laG.position.set(-0.42, 0.15, 0);
  const raG = new THREE.Group(); raG.position.set(0.42, 0.15, 0);
  laG.add(mk(new THREE.BoxGeometry(0.2, 0.55, 0.2), shirtMat)).position.y = -0.25;
  raG.add(mk(new THREE.BoxGeometry(0.2, 0.55, 0.2), shirtMat)).position.y = -0.25;
  torso.add(laG); torso.add(raG);

  const llG = new THREE.Group(); llG.position.set(-0.15, -0.35, 0);
  const rlG = new THREE.Group(); rlG.position.set(0.15, -0.35, 0);
  llG.add(mk(new THREE.BoxGeometry(0.22, 0.9, 0.25), pantsMat)).position.y = -0.45;
  rlG.add(mk(new THREE.BoxGeometry(0.22, 0.9, 0.25), pantsMat)).position.y = -0.45;
  const ls = mk(new THREE.BoxGeometry(0.24,0.12,0.32), shoeMat); ls.position.set(0,-0.95,0.04); llG.add(ls);
  const rs = mk(new THREE.BoxGeometry(0.24,0.12,0.32), shoeMat); rs.position.set(0,-0.95,0.04); rlG.add(rs);
  torso.add(llG); torso.add(rlG);

  return { mesh: g, parts: { torso, head, leftArm: laG, rightArm: raG, leftLeg: llG, rightLeg: rlG } };
}

// ═══════════════════════════════════════
//  PLAYER
// ═══════════════════════════════════════
const player = createCharacter({ skin:0xffcd94, shirt:0xe74c3c, pants:0x222244 });
scene.add(player.mesh);

// ═══════════════════════════════════════
//  CARS
// ═══════════════════════════════════════
function createCar(color) {
  const g = new THREE.Group();
  const bodyMat = new THREE.MeshStandardMaterial({ color, roughness: 0.3, metalness: 0.6 });
  const glassMat = new THREE.MeshStandardMaterial({ color: 0x88ccff, roughness: 0.1, transparent: true, opacity: 0.6 });
  const tireMat  = new THREE.MeshStandardMaterial({ color: 0x111111, roughness: 0.9 });
  const chromeMat= new THREE.MeshStandardMaterial({ color: 0xdddddd, roughness: 0.2, metalness: 0.9 });

  // Body
  const body = new THREE.Mesh(new THREE.BoxGeometry(1.8, 0.55, 3.8), bodyMat);
  body.position.y = 0.55; g.add(body);
  // Cabin
  const cabin = new THREE.Mesh(new THREE.BoxGeometry(1.5, 0.5, 2.0), bodyMat);
  cabin.position.set(0, 1.05, -0.1); g.add(cabin);
  // Windshield
  const wind = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.38, 0.08), glassMat);
  wind.position.set(0, 1.08, 0.84); g.add(wind);
  // Rear window
  const rear = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.38, 0.08), glassMat);
  rear.position.set(0, 1.08, -1.04); g.add(rear);
  // Headlights
  [-0.7, 0.7].forEach(x => {
    const hl = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.12, 0.08), new THREE.MeshStandardMaterial({ color:0xffffcc, emissive:0xffffaa, emissiveIntensity:1.5 }));
    hl.position.set(x, 0.58, 1.92); g.add(hl);
  });
  // Taillights
  [-0.7, 0.7].forEach(x => {
    const tl = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.12, 0.08), new THREE.MeshStandardMaterial({ color:0xff2200, emissive:0xff1100, emissiveIntensity:1.2 }));
    tl.position.set(x, 0.58, -1.92); g.add(tl);
  });
  // Wheels
  const wheelGeo = new THREE.CylinderGeometry(0.28, 0.28, 0.18, 10);
  [[0.95, 0.28, 1.2], [-0.95, 0.28, 1.2], [0.95, 0.28, -1.2], [-0.95, 0.28, -1.2]].forEach(([x,y,z]) => {
    const w = new THREE.Mesh(wheelGeo, tireMat);
    w.rotation.z = Math.PI/2; w.position.set(x,y,z); g.add(w);
    const hub = new THREE.Mesh(new THREE.CylinderGeometry(0.1,0.1,0.22,8), chromeMat);
    hub.rotation.z = Math.PI/2; hub.position.set(x,y,z); g.add(hub);
  });

  g.position.y = 0;
  return g;
}

const cars = [];
const parkedPositions = [];
for (let i = 0; i < CFG.carCount; i++) {
  const color = CFG.carColors[i % CFG.carColors.length];
  const mesh = createCar(color);
  const angle = (i / CFG.carCount) * Math.PI * 2;
  const dist = 6 + Math.random() * 20;
  const x = Math.cos(angle) * dist, z = Math.sin(angle) * dist;
  mesh.position.set(x, 0, z);
  mesh.rotation.y = angle + Math.PI/2;
  scene.add(mesh);
  parkedPositions.push({ x, z });
  cars.push({
    mesh,
    color,
    driver: null,     // npc driving, or 'player'
    speed: 0,
    maxSpeed: 0.18 + Math.random() * 0.08,
    dir: new THREE.Vector3(Math.cos(angle), 0, Math.sin(angle)),
    isParked: true,
  });
}

// ═══════════════════════════════════════
//  NPCs
// ═══════════════════════════════════════
const npcColorPalette = [
  { skin:0xd4a574, shirt:0x2ecc71, pants:0x1a252f },
  { skin:0xf0c27f, shirt:0x9b59b6, pants:0x2c3e50 },
  { skin:0x8d5524, shirt:0xe67e22, pants:0x34495e },
  { skin:0xffcd94, shirt:0x1abc9c, pants:0x2c3e50 },
  { skin:0xc68642, shirt:0xf39c12, pants:0x1a252f },
];
const npcs = [];
for (let i = 0; i < CFG.npcCount; i++) {
  const obj = createCharacter(npcColorPalette[i % npcColorPalette.length]);
  const angle = Math.random() * Math.PI * 2, dist = 5 + Math.random() * 22;
  obj.mesh.position.set(Math.cos(angle)*dist, 0, Math.sin(angle)*dist);
  obj.mesh.rotation.y = Math.random() * Math.PI * 2;
  scene.add(obj.mesh);
  npcs.push({
    obj, speed: 0.03 + Math.random()*0.03,
    dir: new THREE.Vector3(Math.random()-0.5, 0, Math.random()-0.5).normalize(),
    changeDirTimer: 2 + Math.random()*4,
    fleeing: false, fleeTimer: 0,
    bubbleEl: null, bubbleTimer: 0,
  });
}

// ═══════════════════════════════════════
//  COPS
// ═══════════════════════════════════════
function createCopCharacter() {
  return createCharacter({ skin:0xffcd94, shirt:0x1a3a6e, pants:0x111133 });
}
const cops = [];
for (let i = 0; i < CFG.copCount; i++) {
  const obj = createCopCharacter();
  const angle = Math.random() * Math.PI * 2, dist = 10 + Math.random() * 20;
  obj.mesh.position.set(Math.cos(angle)*dist, 0, Math.sin(angle)*dist);
  scene.add(obj.mesh);

  // Blue cap on cop head
  const capMat = new THREE.MeshStandardMaterial({ color: 0x1a3a6e });
  const cap = new THREE.Mesh(new THREE.BoxGeometry(0.38, 0.12, 0.38), capMat);
  cap.position.y = 0.22;
  obj.parts.head.add(cap);
  const brim = new THREE.Mesh(new THREE.BoxGeometry(0.48, 0.05, 0.22), capMat);
  brim.position.set(0, 0.15, 0.2);
  obj.parts.head.add(brim);

  cops.push({
    obj,
    speed: 0.055 + Math.random()*0.02,
    dir: new THREE.Vector3(Math.random()-0.5, 0, Math.random()-0.5).normalize(),
    state: 'patrol',   // patrol | chasePlayer | chaseNpc
    target: null,      // npc being chased
    changeDirTimer: 3 + Math.random()*4,
    bubbleEl: null, bubbleTimer: 0,
  });
}

// ═══════════════════════════════════════
//  ITEMS
// ═══════════════════════════════════════
const itemMeshes = [];
const itemGeo = new THREE.BoxGeometry(0.5, 0.5, 0.5);
const itemMatCache = {};
function spawnItems() {
  for (let i = 0; i < 12; i++) {
    const def = CFG.itemDefs[Math.floor(Math.random() * CFG.itemDefs.length)];
    const angle = Math.random()*Math.PI*2, dist = 4 + Math.random()*20;
    if (!itemMatCache[def.name]) {
      itemMatCache[def.name] = new THREE.MeshStandardMaterial({ color:def.color, emissive:def.color, emissiveIntensity:0.6, roughness:0.4 });
    }
    const mesh = new THREE.Mesh(itemGeo, itemMatCache[def.name]);
    mesh.position.set(Math.cos(angle)*dist, 0.5, Math.sin(angle)*dist);
    scene.add(mesh);
    itemMeshes.push({ mesh, def, collected: false });
  }
}
spawnItems();

// ═══════════════════════════════════════
//  CAMERA
// ═══════════════════════════════════════
const controls = new (window.OrbitControls || THREE.OrbitControls)(camera, renderer.domElement);
controls.enableDamping = true; controls.dampingFactor = 0.06;
controls.minDistance = 4; controls.maxDistance = 20;
controls.maxPolarAngle = Math.PI/2 - 0.04;
controls.target.copy(player.mesh.position);

// ═══════════════════════════════════════
//  JOYSTICK
// ═══════════════════════════════════════
const joystickZone = document.getElementById('joystick-zone');
const joystickKnob = document.getElementById('joystick-knob');
const speedFill = document.getElementById('speed-fill');
let jActive = false, jCenter = {x:0,y:0};
const getPos = e => e.touches ? {x:e.touches[0].clientX, y:e.touches[0].clientY} : {x:e.clientX, y:e.clientY};

joystickZone.addEventListener('mousedown', e => { e.preventDefault(); const r=joystickZone.getBoundingClientRect(); jCenter={x:r.left+r.width/2,y:r.top+r.height/2}; jActive=true; updateJoy(getPos(e)); });
window.addEventListener('mousemove', e => { if(!jActive) return; e.preventDefault(); updateJoy(getPos(e)); });
window.addEventListener('mouseup', () => { jActive=false; joystickKnob.style.transform='translate(-50%,-50%)'; state.moveForward=0; state.moveRight=0; state.isMoving=false; speedFill.style.height='0%'; });
joystickZone.addEventListener('touchstart', e => { e.preventDefault(); const r=joystickZone.getBoundingClientRect(); jCenter={x:r.left+r.width/2,y:r.top+r.height/2}; jActive=true; updateJoy(getPos(e)); }, {passive:false});
window.addEventListener('touchmove', e => { if(!jActive) return; e.preventDefault(); updateJoy(getPos(e)); }, {passive:false});
window.addEventListener('touchend', () => { jActive=false; joystickKnob.style.transform='translate(-50%,-50%)'; state.moveForward=0; state.moveRight=0; state.isMoving=false; speedFill.style.height='0%'; });

function updateJoy(pos) {
  let dx = pos.x-jCenter.x, dy = pos.y-jCenter.y;
  const dist = Math.sqrt(dx*dx+dy*dy), max = CFG.joystickMaxDist;
  if (dist > max) { const a=Math.atan2(dy,dx); dx=Math.cos(a)*max; dy=Math.sin(a)*max; }
  joystickKnob.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;
  state.moveForward = -dy/max; state.moveRight = dx/max;
  const spd = Math.sqrt(state.moveForward**2+state.moveRight**2);
  state.isMoving = spd > 0.1;
  speedFill.style.height = `${Math.min(spd*100,100)}%`;
}

// Sprint
const btnRun = document.getElementById('btn-run');
btnRun.addEventListener('touchstart', ()=>state.isSprinting=true, {passive:true});
btnRun.addEventListener('touchend', ()=>state.isSprinting=false);
btnRun.addEventListener('mousedown', ()=>state.isSprinting=true);
btnRun.addEventListener('mouseup', ()=>state.isSprinting=false);

// Interact
document.getElementById('btn-pickup').addEventListener('click', interact);
document.getElementById('btn-pickup').addEventListener('touchstart', e=>{e.preventDefault();interact();},{passive:false});

const keys = {};
window.addEventListener('keydown', e => { keys[e.code]=true; if(e.code==='KeyE') interact(); });
window.addEventListener('keyup', e => keys[e.code]=false);

// ═══════════════════════════════════════
//  INTERACT (pickup item OR enter/exit car)
// ═══════════════════════════════════════
function interact() {
  // Exit car
  if (state.inCar) {
    exitCar(); return;
  }
  // Enter nearby car
  if (state.nearCar) {
    enterCar(state.nearCar); return;
  }
  // Pick up item
  if (state.nearItem) {
    const item = state.nearItem;
    if (item.collected) return;
    if (addToInventory(item.def)) {
      item.collected = true;
      scene.remove(item.mesh);
      showNotify(`+ ${item.def.emoji} ${item.def.name}`);
      if (item.def.name === 'MedKit') { state.health = Math.min(100, state.health+25); updateStats(); }
      if (item.def.name === 'Star') { gainWanted(1); }
      state.nearItem = null;
      document.getElementById('pickup-popup').classList.remove('show');
    }
  }
}

function enterCar(car) {
  state.inCar = car;
  car.driver = 'player';
  car.isParked = false;
  // Hide player mesh, attach to car
  player.mesh.visible = false;
  gainWanted(1);
  showNotify('🚗 Car confiscated!', 'red');
  document.getElementById('car-hud').classList.add('active');
}

function exitCar() {
  const car = state.inCar;
  car.driver = null;
  car.isParked = true;
  car.speed = 0;
  // Place player next to car
  player.mesh.position.set(
    car.mesh.position.x + 2,
    0,
    car.mesh.position.z
  );
  player.mesh.visible = true;
  state.inCar = null;
  document.getElementById('car-hud').classList.remove('active');
  showNotify('🚶 Exited vehicle');
}

// ═══════════════════════════════════════
//  INVENTORY
// ═══════════════════════════════════════
function updateInventoryUI() {
  for (let i = 0; i < 4; i++) {
    const slot = document.getElementById(`slot-${i}`);
    slot.innerHTML = '';
    if (state.inventory[i]) {
      slot.classList.add('filled');
      slot.textContent = state.inventory[i].emoji;
      const q = document.createElement('span'); q.className='qty';
      if (state.inventory[i].qty > 1) q.textContent = `x${state.inventory[i].qty}`;
      slot.appendChild(q);
    } else {
      slot.classList.remove('filled');
    }
  }
}

function addToInventory(def) {
  const ex = state.inventory.find(x => x.name===def.name);
  if (ex) { ex.qty++; updateInventoryUI(); return true; }
  if (state.inventory.length < 4) { state.inventory.push({emoji:def.emoji,name:def.name,qty:1}); updateInventoryUI(); return true; }
  showNotify('⚠ INVENTORY FULL');
  return false;
}

// ═══════════════════════════════════════
//  STATS
// ═══════════════════════════════════════
function updateStats() {
  document.getElementById('health-bar').style.width = state.health+'%';
  document.getElementById('health-val').textContent = state.health;
  document.getElementById('wanted-bar').style.width = (state.wanted/5*100)+'%';
  document.getElementById('wanted-val').textContent = '★'.repeat(state.wanted)+'☆'.repeat(5-state.wanted);
}
updateStats();

function gainWanted(n) {
  state.wanted = Math.min(5, state.wanted + n);
  updateStats();
  state.wantedFlashTimer = 0.4;
  document.getElementById('wanted-flash').classList.add('active');
  // Alert nearby cops
  for (const cop of cops) {
    if (cop.state !== 'chasePlayer') {
      cop.state = 'chasePlayer';
      cop.target = null;
    }
  }
}

function loseWanted() {
  if (state.wanted > 0) {
    state.wanted--;
    updateStats();
    if (state.wanted === 0) {
      showNotify('✅ Lost the cops', 'blue');
      for (const cop of cops) cop.state = 'patrol';
    }
  }
}

// ═══════════════════════════════════════
//  NOTIFICATIONS
// ═══════════════════════════════════════
function showNotify(msg, type) {
  const div = document.createElement('div');
  div.className = 'notify-item' + (type ? ' '+type : '');
  div.textContent = msg;
  document.getElementById('notify').appendChild(div);
  setTimeout(() => div.remove(), 3100);
}

// ═══════════════════════════════════════
//  SPEECH BUBBLES
// ═══════════════════════════════════════
function showBubble(entity, text, isCop) {
  if (entity.bubbleEl) return;
  const div = document.createElement('div');
  div.className = 'speech-bubble' + (isCop ? ' cop' : '');
  div.textContent = text;
  document.getElementById('hud').appendChild(div);
  entity.bubbleEl = div;
  entity.bubbleTimer = 2.5;
}

function updateBubbles(entities, dt) {
  const w2 = innerWidth/2, h2 = innerHeight/2;
  for (const e of entities) {
    if (!e.bubbleEl) continue;
    e.bubbleTimer -= dt;
    if (e.bubbleTimer <= 0) { e.bubbleEl.remove(); e.bubbleEl = null; continue; }
    const pos = new THREE.Vector3();
    e.obj.mesh.getWorldPosition(pos); pos.y += 2.4;
    const p = pos.project(camera);
    if (p.z > 1) { e.bubbleEl.style.display='none'; continue; }
    e.bubbleEl.style.display='';
    e.bubbleEl.style.left = (p.x*w2+w2)+'px';
    e.bubbleEl.style.top  = (-p.y*h2+h2)+'px';
  }
}

// ═══════════════════════════════════════
//  MINIMAP
// ═══════════════════════════════════════
const minimapCanvas = document.getElementById('minimap');
const mctx = minimapCanvas.getContext('2d');
const MMAP_SCALE = 130/60;

function drawMinimap() {
  const W=130, H=130;
  mctx.fillStyle='#111'; mctx.fillRect(0,0,W,H);
  const px=player.mesh.position.x, pz=player.mesh.position.z;
  const mx = x => W/2+(x-px)*MMAP_SCALE;
  const mz = z => H/2+(z-pz)*MMAP_SCALE;

  mctx.fillStyle='#2a2a3a';
  for (const b of buildings) mctx.fillRect(mx(b.x-b.bw/2), mz(b.z-b.bd/2), b.bw*MMAP_SCALE, b.bd*MMAP_SCALE);

  // Items
  for (const item of itemMeshes) {
    if (item.collected) continue;
    const x=mx(item.mesh.position.x), z=mz(item.mesh.position.z);
    if (x<0||x>W||z<0||z>H) continue;
    mctx.fillStyle='#'+item.def.color.toString(16).padStart(6,'0');
    mctx.beginPath(); mctx.arc(x,z,2.5,0,Math.PI*2); mctx.fill();
  }

  // Cars
  for (const car of cars) {
    const x=mx(car.mesh.position.x), z=mz(car.mesh.position.z);
    if (x<0||x>W||z<0||z>H) continue;
    mctx.fillStyle = car.driver==='player' ? '#ffe000' : '#'+(car.color).toString(16).padStart(6,'0');
    mctx.fillRect(x-3, z-2, 6, 4);
  }

  // NPCs
  mctx.fillStyle='#aaa';
  for (const n of npcs) {
    const x=mx(n.obj.mesh.position.x), z=mz(n.obj.mesh.position.z);
    if (x<0||x>W||z<0||z>H) continue;
    mctx.beginPath(); mctx.arc(x,z,2,0,Math.PI*2); mctx.fill();
  }

  // Cops
  for (const c of cops) {
    const x=mx(c.obj.mesh.position.x), z=mz(c.obj.mesh.position.z);
    if (x<0||x>W||z<0||z>H) continue;
    mctx.fillStyle = c.state==='chasePlayer' ? '#ef4444' : '#3b82f6';
    mctx.beginPath(); mctx.arc(x,z,3,0,Math.PI*2); mctx.fill();
  }
}

// ═══════════════════════════════════════
//  COLLISION
// ═══════════════════════════════════════
function resolveCollisions(pos, radius) {
  radius = radius || 0.4;
  for (const b of buildings) {
    const hw=b.bw/2+radius, hd=b.bd/2+radius;
    if (Math.abs(pos.x-b.x)<hw && Math.abs(pos.z-b.z)<hd) {
      const ox=hw-Math.abs(pos.x-b.x), oz=hd-Math.abs(pos.z-b.z);
      if (ox<oz) pos.x+=ox*Math.sign(pos.x-b.x);
      else pos.z+=oz*Math.sign(pos.z-b.z);
    }
  }
}

function steerTowards(pos, target, speed) {
  const dir = new THREE.Vector3(target.x-pos.x, 0, target.z-pos.z);
  const len = dir.length();
  if (len < 0.1) return new THREE.Vector3();
  return dir.normalize().multiplyScalar(speed);
}

// ═══════════════════════════════════════
//  KEYBOARD
// ═══════════════════════════════════════
function applyKeyboard() {
  if (jActive) return;
  state.moveForward=0; state.moveRight=0;
  if (keys['KeyW']||keys['ArrowUp'])    state.moveForward=1;
  if (keys['KeyS']||keys['ArrowDown'])  state.moveForward=-1;
  if (keys['KeyA']||keys['ArrowLeft'])  state.moveRight=-1;
  if (keys['KeyD']||keys['ArrowRight']) state.moveRight=1;
  state.isSprinting=!!(keys['ShiftLeft']||keys['ShiftRight']);
  const spd=Math.sqrt(state.moveForward**2+state.moveRight**2);
  state.isMoving=spd>0.05;
  speedFill.style.height=`${Math.min(spd*100,100)}%`;
}

// ═══════════════════════════════════════
//  PROXIMITY CHECK
// ═══════════════════════════════════════
function checkProximity() {
  const pp = state.inCar ? state.inCar.mesh.position : player.mesh.position;

  // Near item
  let closestItem=null, closestItemDist=CFG.pickupRadius;
  for (const item of itemMeshes) {
    if (item.collected) continue;
    const d=pp.distanceTo(item.mesh.position);
    if (d<closestItemDist) { closestItemDist=d; closestItem=item; }
  }
  state.nearItem = closestItem;

  // Near car (only on foot)
  let closestCar=null, closestCarDist=3.5;
  if (!state.inCar) {
    for (const car of cars) {
      if (car.driver==='player') continue;
      const d=pp.distanceTo(car.mesh.position);
      if (d<closestCarDist) { closestCarDist=d; closestCar=car; }
    }
  }
  state.nearCar = closestCar;

  // Popup text
  const popup = document.getElementById('pickup-popup');
  if (state.inCar) {
    popup.textContent = '🚪 EXIT CAR  [E]'; popup.classList.add('show');
  } else if (closestCar) {
    popup.textContent = '🚗 STEAL CAR  [E]'; popup.classList.add('show');
  } else if (closestItem) {
    popup.textContent = `${closestItem.def.emoji}  PICK UP  [E]`; popup.classList.add('show');
  } else {
    popup.classList.remove('show');
  }
}

// ═══════════════════════════════════════
//  ANIM HELPERS
// ═══════════════════════════════════════
function animateWalk(parts, t, offset, running) {
  const ws = running ? 14 : 9;
  const la = Math.sin(t*ws+offset) * (running ? 0.7 : 0.45);
  parts.leftLeg.rotation.x  =  la;
  parts.rightLeg.rotation.x = -la;
  parts.leftArm.rotation.x  = -la;
  parts.rightArm.rotation.x  =  la;
}
function animateIdle(parts) {
  const lp = x => THREE.MathUtils.lerp(x, 0, 0.12);
  parts.leftLeg.rotation.x  = lp(parts.leftLeg.rotation.x);
  parts.rightLeg.rotation.x = lp(parts.rightLeg.rotation.x);
  parts.leftArm.rotation.x  = lp(parts.leftArm.rotation.x);
  parts.rightArm.rotation.x = lp(parts.rightArm.rotation.x);
}
function faceDir(mesh, dir) {
  const target = Math.atan2(dir.x, dir.z);
  let diff = target - mesh.rotation.y;
  while(diff>Math.PI)diff-=Math.PI*2; while(diff<-Math.PI)diff+=Math.PI*2;
  mesh.rotation.y += diff * CFG.rotSpeed;
}

// ═══════════════════════════════════════
//  MAIN LOOP
// ═══════════════════════════════════════
const clock = new THREE.Clock();
let titleTimer = 3.5;
let wantedDecayTimer = 0;

function animate() {
  requestAnimationFrame(animate);
  const dt = clock.getDelta();
  const t  = clock.getElapsedTime();

  applyKeyboard();
  updateDayNight(dt);

  // Title fade
  if (titleTimer > 0) {
    titleTimer -= dt;
    if (titleTimer <= 0) {
      document.getElementById('city-title').style.opacity='0';
      document.getElementById('city-subtitle').style.opacity='0';
    }
  }

  // Wanted flash
  if (state.wantedFlashTimer > 0) {
    state.wantedFlashTimer -= dt;
    if (state.wantedFlashTimer <= 0) document.getElementById('wanted-flash').classList.remove('active');
  }

  // Wanted decay (lose stars if far from cops for a while)
  if (state.wanted > 0) {
    wantedDecayTimer += dt;
    if (wantedDecayTimer > 15) { wantedDecayTimer = 0; loseWanted(); }
  } else { wantedDecayTimer = 0; }

  // ── PLAYER (on foot) ──
  if (!state.inCar) {
    if (state.isMoving) {
      const camDir = new THREE.Vector3(); camera.getWorldDirection(camDir); camDir.y=0; camDir.normalize();
      const camRight = new THREE.Vector3().crossVectors(camDir, new THREE.Vector3(0,1,0));
      const spd = CFG.moveSpeed * (state.isSprinting ? CFG.runMultiplier : 1);
      const move = new THREE.Vector3()
        .addScaledVector(camDir, state.moveForward)
        .addScaledVector(camRight, state.moveRight)
        .normalize().multiplyScalar(spd);
      const next = player.mesh.position.clone().add(move);
      resolveCollisions(next);
      player.mesh.position.copy(next);
      faceDir(player.mesh, move);
      animateWalk(player.parts, t, 0, state.isSprinting);
      player.parts.torso.position.y = 1.35 + Math.abs(Math.sin(t*(state.isSprinting?14:9)*2))*0.05;
    } else {
      animateIdle(player.parts);
      player.parts.torso.position.y = THREE.MathUtils.lerp(player.parts.torso.position.y, 1.35, 0.1);
    }
  }

  // ── PLAYER IN CAR ──
  if (state.inCar) {
    const car = state.inCar;
    const camDir = new THREE.Vector3(); camera.getWorldDirection(camDir); camDir.y=0; camDir.normalize();
    const camRight = new THREE.Vector3().crossVectors(camDir, new THREE.Vector3(0,1,0));

    if (state.isMoving) {
      const inputDir = new THREE.Vector3()
        .addScaledVector(camDir, state.moveForward)
        .addScaledVector(camRight, state.moveRight)
        .normalize();
      car.speed = Math.min(car.speed + 0.008, car.maxSpeed * (state.isSprinting ? 1.6 : 1));
      car.dir.lerp(inputDir, 0.08).normalize();
    } else {
      car.speed *= 0.92;
    }

    const move = car.dir.clone().multiplyScalar(car.speed);
    const next = car.mesh.position.clone().add(move);
    resolveCollisions(next, 1.2);
    car.mesh.position.copy(next);
    if (car.speed > 0.005) {
      const target = Math.atan2(car.dir.x, car.dir.z);
      let diff = target - car.mesh.rotation.y;
      while(diff>Math.PI)diff-=Math.PI*2; while(diff<-Math.PI)diff+=Math.PI*2;
      car.mesh.rotation.y += diff * 0.1;
    }
    // Car speed HUD
    document.getElementById('car-speed-val').textContent = Math.round(car.speed * 600);
  }

  // ── NPCs ──
  for (let i=0; i<npcs.length; i++) {
    const npc = npcs[i];
    npc.changeDirTimer -= dt;

    if (npc.fleeing) {
      npc.fleeTimer -= dt;
      if (npc.fleeTimer <= 0) npc.fleeing = false;
    }

    if (npc.changeDirTimer <= 0) {
      if (!npc.fleeing) npc.dir.set(Math.random()-0.5, 0, Math.random()-0.5).normalize();
      npc.changeDirTimer = 1.5 + Math.random()*3;
      const distToPlayer = npc.obj.mesh.position.distanceTo(player.mesh.position);
      if (distToPlayer < 6 && Math.random() < 0.3) {
        showBubble(npc, CFG.npcPhrases[Math.floor(Math.random()*CFG.npcPhrases.length)], false);
      }
    }

    const spd = npc.fleeing ? npc.speed * 1.8 : npc.speed;
    const next = npc.obj.mesh.position.clone().addScaledVector(npc.dir, spd);
    if (Math.abs(next.x)>45||Math.abs(next.z)>45) npc.dir.negate();
    else npc.obj.mesh.position.copy(next);

    npc.obj.mesh.rotation.y = Math.atan2(npc.dir.x, npc.dir.z);
    animateWalk(npc.obj.parts, t, i*1.3, npc.fleeing);
  }

  // ── COPS ──
  for (let i=0; i<cops.length; i++) {
    const cop = cops[i];

    // Decide state
    if (state.wanted > 0 && cop.state !== 'chasePlayer') cop.state = 'chasePlayer';
    if (state.wanted === 0 && cop.state === 'chasePlayer') {
      cop.state = 'patrol'; cop.target = null;
    }

    // Randomly assign cop to chase a random NPC if patrolling
    if (cop.state === 'patrol') {
      cop.changeDirTimer -= dt;
      if (cop.changeDirTimer <= 0) {
        cop.changeDirTimer = 3 + Math.random()*5;
        if (Math.random() < 0.25 && npcs.length > 0) {
          cop.state = 'chaseNpc';
          cop.target = npcs[Math.floor(Math.random()*npcs.length)];
        } else {
          cop.dir.set(Math.random()-0.5, 0, Math.random()-0.5).normalize();
        }
      }
      const next = cop.obj.mesh.position.clone().addScaledVector(cop.dir, cop.speed*0.6);
      if (Math.abs(next.x)>45||Math.abs(next.z)>45) cop.dir.negate();
      else cop.obj.mesh.position.copy(next);
      cop.obj.mesh.rotation.y = Math.atan2(cop.dir.x, cop.dir.z);
      animateWalk(cop.obj.parts, t, i*2.1, false);
    }

    if (cop.state === 'chasePlayer') {
      const target = state.inCar ? state.inCar.mesh.position : player.mesh.position;
      const dist = cop.obj.mesh.position.distanceTo(target);
      const spd = dist < 15 ? cop.speed * 1.4 : cop.speed;
      const move = steerTowards(cop.obj.mesh.position, target, spd);
      cop.obj.mesh.position.add(move);
      faceDir(cop.obj.mesh, move);
      animateWalk(cop.obj.parts, t, i*2.1, true);

      // Caught player on foot
      if (dist < 1.5 && !state.inCar) {
        state.health = Math.max(0, state.health - 10);
        updateStats();
        showNotify('👮 Busted! -10 HP', 'red');
        showBubble(cop, CFG.copPhrases[Math.floor(Math.random()*CFG.copPhrases.length)], true);
        // Push player away
        const pushDir = new THREE.Vector3().subVectors(player.mesh.position, cop.obj.mesh.position).normalize();
        player.mesh.position.addScaledVector(pushDir, 3);
        state.wanted = Math.max(0, state.wanted - 1);
        updateStats();
        if (state.wanted === 0) { cop.state='patrol'; for(const c of cops) c.state='patrol'; }
        wantedDecayTimer = 0;
      }

      // Cop shouts when chasing
      if (Math.random() < 0.004) showBubble(cop, CFG.copPhrases[Math.floor(Math.random()*CFG.copPhrases.length)], true);
    }

    if (cop.state === 'chaseNpc') {
      if (!cop.target) { cop.state='patrol'; continue; }
      const target = cop.target.obj.mesh.position;
      const dist = cop.obj.mesh.position.distanceTo(target);
      const move = steerTowards(cop.obj.mesh.position, target, cop.speed*1.1);
      cop.obj.mesh.position.add(move);
      faceDir(cop.obj.mesh, move);
      animateWalk(cop.obj.parts, t, i*2.1, true);

      // NPC flees cop
      if (dist < 8) {
        const npc = cop.target;
        npc.fleeing = true;
        npc.fleeTimer = 4;
        const fleeDir = new THREE.Vector3().subVectors(npc.obj.mesh.position, cop.obj.mesh.position).normalize();
        npc.dir.copy(fleeDir);
      }
      if (Math.random() < 0.004) showBubble(cop, CFG.copNpcPhrases[Math.floor(Math.random()*CFG.copNpcPhrases.length)], true);

      // Caught NPC
      if (dist < 1.5) {
        showNotify(`👮 Cop nabbed someone`);
        showBubble(cop, "Got em!", true);
        cop.state = 'patrol';
        cop.target.fleeing = false;
        cop.target = null;
        cop.changeDirTimer = 4;
      }
    }
  }

  updateBubbles(npcs, dt);
  updateBubbles(cops, dt);

  // Items float
  for (const item of itemMeshes) {
    if (item.collected) continue;
    item.mesh.position.y = 0.5 + Math.sin(t*2+item.mesh.position.x)*0.12;
    item.mesh.rotation.y += 0.04;
  }

  checkProximity();
  drawMinimap();

  // Camera follows player or car
  const camTarget = state.inCar ? state.inCar.mesh.position : player.mesh.position;
  controls.target.lerp(camTarget, 0.1);
  controls.update();
  renderer.render(scene, camera);
}

window.addEventListener('resize', () => {
  camera.aspect = innerWidth/innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(innerWidth, innerHeight);
});

animate();
showNotify('🌆 Welcome to 0x City');
setTimeout(() => showNotify('🎮 Joystick/WASD to move'), 800);
setTimeout(() => showNotify('🚗 [E] near a car to steal it'), 1600);
setTimeout(() => showNotify('👮 Cops will chase you for crimes'), 2400);

})();
</script>
</body>
</html>
